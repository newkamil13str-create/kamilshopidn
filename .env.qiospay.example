# ─── Qiospay H2H Integration ──────────────────────────────────────────────────
# Ambil dari dashboard: https://qiospay.id/mitra → Integrasi transaksi → Transaksi IP

# Username/Member ID yang terdaftar di Qiospay
QIOSPAY_MEMBER_ID=username_kamu

# PIN transaksi yang dibuat di dashboard Qiospay
QIOSPAY_PIN=1234

# Password akun Qiospay (sama dengan saat mendaftar)
QIOSPAY_PASSWORD=passwordkamu

# ─── Markup harga top up (opsional) ───────────────────────────────────────────
# Persentase markup di atas harga supplier Qiospay (default: 10 = 10%)
# Contoh: harga supplier Rp10.000 + 10% = Rp11.000 harga jual
NEXT_PUBLIC_TOPUP_MARKUP=10

# ─── IP Server (wajib didaftarkan di dashboard Qiospay) ───────────────────────
# Daftarkan IP server deploy kamu di:
# qiospay.id/mitra → Integrasi transaksi → Transaksi IP → IP Address
# IP_SERVER_KAMU=xxx.xxx.xxx.xxx

# ─── Callback URL (sudah otomatis) ────────────────────────────────────────────
# Daftarkan juga URL callback ini di dashboard Qiospay:
# {NEXT_PUBLIC_SITE_URL}/api/topup-game/callback
# Contoh: https://kamilshop.my.id/api/topup-game/callback
